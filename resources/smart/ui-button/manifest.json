{
  "schema": "larena.ui.smart_manifest.v1",
  "key": "ui.button",
  "version": "1.0.0",
  "owner_package": "larena/ui",
  "kind": "smart",
  "props": {
    "type": "object",
    "properties": {
      "text": {"type": "string", "minLength": 1, "maxLength": 120, "pattern": "\\S"},
      "size": {"type": "string", "enum": ["1/3", "1/2", "1", "2", "3"]},
      "type": {"type": "string", "enum": ["default", "tonal", "outline", "link"]},
      "scheme": {"type": "string", "enum": ["primary", "secondary", "on-surface"]},
      "radius": {"type": "string", "enum": ["", "default", "square", "rounded"]},
      "loading": {"type": "boolean"},
      "disabled": {"type": "boolean"},
      "native-type": {"type": "string", "enum": ["button", "submit", "reset"]},
      "aria-label": {"type": "string", "minLength": 1, "maxLength": 120, "pattern": "\\S"}
    },
    "required": ["text", "size", "type", "scheme", "loading", "disabled", "native-type", "aria-label"],
    "additionalProperties": false
  },
  "slots": {},
  "events": {
    "click": {"kind": "dom", "backend_handler_binding": false},
    "focusin": {"kind": "dom", "backend_handler_binding": false},
    "focusout": {"kind": "dom", "backend_handler_binding": false},
    "mouseenter": {"kind": "dom", "backend_handler_binding": false},
    "mouseleave": {"kind": "dom", "backend_handler_binding": false},
    "sf-connected": {"kind": "lifecycle", "backend_handler_binding": false},
    "sf-before-render": {"kind": "lifecycle", "backend_handler_binding": false},
    "sf-after-render": {"kind": "lifecycle", "backend_handler_binding": false},
    "sf-updated": {"kind": "lifecycle", "backend_handler_binding": false},
    "sf-props-change": {"kind": "lifecycle", "backend_handler_binding": false},
    "sf-disconnected": {"kind": "lifecycle", "backend_handler_binding": false}
  },
  "views": {"default": {}, "admin": {}},
  "presets": {
    "primary": {"props": {"type": "default", "scheme": "primary"}},
    "on_surface": {"props": {"type": "default", "scheme": "on-surface"}},
    "secondary": {"props": {"type": "tonal", "scheme": "secondary"}},
    "tonal_on_surface": {"props": {"type": "tonal", "scheme": "on-surface"}},
    "outline": {"props": {"type": "outline", "scheme": "primary"}},
    "outline_on_surface": {"props": {"type": "outline", "scheme": "on-surface"}},
    "link": {"props": {"type": "link", "scheme": "primary"}},
    "link_on_surface": {"props": {"type": "link", "scheme": "on-surface"}}
  },
  "constraints": {
    "allowed_combinations": [
      {
        "keys": ["type", "scheme"],
        "values": [
          ["default", "primary"],
          ["default", "on-surface"],
          ["tonal", "secondary"],
          ["tonal", "on-surface"],
          ["outline", "primary"],
          ["outline", "on-surface"],
          ["link", "primary"],
          ["link", "on-surface"]
        ]
      }
    ],
    "requires": [
      {"when": {"loading": true}, "then": {"disabled": true}}
    ]
  },
  "render": {"strategy": "host", "renderer": "ui.sf_element"},
  "frontend": {"runtime": "simai-framework", "tag": "sf-button"},
  "assets": [
    {"key": "simai.framework.core.css", "kind": "css", "critical": true},
    {"key": "simai.framework.core.js", "kind": "javascript", "critical": true},
    {"key": "simai.framework.smart_base.js", "kind": "javascript", "critical": true},
    {"key": "simai.framework.bridge.js", "kind": "javascript", "critical": true},
    {"key": "simai.framework.sf_button.js", "kind": "javascript", "critical": true}
  ],
  "atlas": {
    "visible": true,
    "title": "Button",
    "description": "A backend-first action button rendered by SmartManager through the pinned Simai Framework runtime.",
    "category": "actions",
    "order": 10,
    "status": "developer_testable",
    "states": ["default", "hover", "focus", "active", "loading", "disabled"],
    "accessibility": ["native_button", "visible_focus", "disabled_semantics", "accessible_name"],
    "product_href": "/admin/docara/pages/create",
    "example_props": {
      "text": "Save",
      "size": "1",
      "type": "default",
      "scheme": "primary",
      "loading": false,
      "disabled": false,
      "native-type": "button",
      "aria-label": "Save"
    },
    "controls": [
      {"key": "text", "source": "prop", "widget": "text", "min_length": 1, "max_length": 120, "mirror_props": ["aria-label"]},
      {"key": "variant", "source": "preset", "widget": "select", "default": "primary"},
      {"key": "size", "source": "prop", "widget": "select"},
      {"key": "radius", "source": "prop", "widget": "select", "options": ["", "square", "rounded"], "default": "", "omit_empty": true},
      {"key": "loading", "source": "prop", "widget": "boolean", "linked_props": {"disabled": true}},
      {"key": "disabled", "source": "prop", "widget": "boolean"}
    ],
    "code_preview": {"adapter": "smart_manager_php_v1", "omit_defaults": false},
    "i18n": {
      "en": {
        "title": "Button",
        "description": "A backend-first action button rendered by SmartManager through the pinned Simai Framework runtime.",
        "controls": {"text": "Text", "variant": "Variant", "size": "Size", "radius": "Corner radius", "loading": "Loading", "disabled": "Disabled"},
        "options": {
          "variant": {"primary": "Primary", "on_surface": "Default on surface", "secondary": "Secondary tonal", "tonal_on_surface": "Tonal on surface", "outline": "Outline primary", "outline_on_surface": "Outline on surface", "link": "Link primary", "link_on_surface": "Link on surface"},
          "size": {"1/3": "Extra small · 1/3", "1/2": "Small · 1/2", "1": "Default · 1", "2": "Large · 2", "3": "Extra large · 3"},
          "radius": {"": "Simai Framework default", "square": "Square", "rounded": "Rounded"}
        }
      },
      "ru": {
        "title": "Кнопка",
        "description": "Backend-first кнопка, которую SmartManager отрисовывает через зафиксированный runtime Simai Framework.",
        "controls": {"text": "Текст", "variant": "Вариант", "size": "Размер", "radius": "Скругление", "loading": "Загрузка", "disabled": "Отключена"},
        "options": {
          "variant": {"primary": "Основная", "on_surface": "Обычная на поверхности", "secondary": "Вторичная тональная", "tonal_on_surface": "Тональная на поверхности", "outline": "Контурная основная", "outline_on_surface": "Контурная на поверхности", "link": "Ссылка основная", "link_on_surface": "Ссылка на поверхности"},
          "size": {"1/3": "Очень маленькая · 1/3", "1/2": "Маленькая · 1/2", "1": "Обычная · 1", "2": "Большая · 2", "3": "Очень большая · 3"},
          "radius": {"": "По умолчанию Simai Framework", "square": "Без скругления", "rounded": "Полностью скруглённая"}
        }
      }
    }
  },
  "provenance": {
    "source": "larena/ui",
    "runtime_lock": "resources/sf/runtime-lock.json",
    "upstream_component": "simai/ui-smart:smart/buttons",
    "reference_status": "source_backed"
  }
}
