{
  "name": "larena/ui",
  "description": "Larena UI: Universal UI/frontend package for Larena smart components, backend-first rendering, hydration, design packs, UI asset graph, component registry, playground and frontend behavior contracts.",
  "type": "library",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Rim Zabarov",
      "homepage": "https://github.com/zabarov"
    }
  ],
  "require": {
    "php": "^8.3",
    "larena/dataview": "dev-main"
  },
  "repositories": [
    {"type": "path", "url": "../dataview", "options": {"symlink": true}}
  ],
  "autoload": {
    "psr-4": {
      "Larena\\Ui\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Larena\\Ui\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0"
  },
  "scripts": {
    "test": ["@php -d zend.assertions=1 -d assert.exception=1 scripts/run-unit-tests.php", "@php -d zend.assertions=1 -d assert.exception=1 tests/Unit/AdminDataviewRendererTest.php", "@php -d zend.assertions=1 -d assert.exception=1 tests/Unit/AdminUiLabRendererTest.php", "@php -d zend.assertions=1 -d assert.exception=1 tests/Unit/SourceBackedComponentRegistryTest.php", "@php -d zend.assertions=1 -d assert.exception=1 tests/Unit/SmartTest.php", "@php -d zend.assertions=1 -d assert.exception=1 tests/Unit/FrontendRuntimeAssetResolverTest.php"],
    "test:unit": "@php -d zend.assertions=1 -d assert.exception=1 scripts/run-unit-tests.php",
    "lint": "@php scripts/lint.php",
    "analyse": "@php scripts/analyse.php",
    "validate:larena": "@php scripts/validate-larena-package.php",
    "evidence:check": "@php scripts/check-evidence.php",
    "scope:check": "@php tools/larena-scope-check.php",
    "quality:gate": [
      "@validate:larena",
      "@lint",
      "@analyse",
      "@test",
      "@evidence:check",
      "@scope:check"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
